# Copy this file to .env and fill in the values before running docker compose.
# Never commit .env to version control.

# ── Database credentials ───────────────────────────────────────────────────
# These are used by both the postgres container (to create the DB) and the
# backend container (to connect to it). Keep them in sync.
PGUSER=finance
PGPASSWORD=changeme
PGDATABASE=finance_tracker

# ── Frontend API URL ───────────────────────────────────────────────────────
# The address your BROWSER uses to reach the backend.
# Set this to your homelab's LAN IP or hostname — not "localhost",
# because localhost in a browser means the user's own machine, not your server.
#
# Examples:
#   VITE_API_URL=http://192.168.1.100:4000/api
#   VITE_API_URL=http://homelab:4000/api
VITE_API_URL=http://YOUR_HOMELAB_IP:4000/api
