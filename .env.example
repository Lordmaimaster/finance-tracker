# Copy this file to .env and fill in the values before running docker compose.
# Never commit .env to version control.

# ── Database credentials ───────────────────────────────────────────────────
PGUSER=app
PGPASSWORD=changeme
PGDATABASE=finance_tracker

# ── Application port ───────────────────────────────────────────────────────
PORT=3000

# ── (Optional) Frontend API URL ────────────────────────────────────────────
# Only set this if you are serving the backend on a different origin than the
# frontend (e.g. behind a reverse proxy that splits traffic by path).
# For the standard single-container setup this can be left blank.
#
# VITE_API_URL=http://192.168.1.100:3000/api
